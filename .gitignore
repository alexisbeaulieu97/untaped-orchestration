# Python bytecode and build output
__pycache__/
*.py[codz]
*.egg-info/
build/
dist/

# Virtual environments and tool caches
.venv/
.uv-cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local secrets and environment files
.env
.envrc

# Editor noise
.DS_Store

# Local orchestration runtime/editor artifacts only; canonical state and views are tracked.
.untaped/orchestration/**/.lock
.untaped/orchestration/**/.DS_Store
.untaped/orchestration/**/.*.untaped-tmp-*
.untaped/orchestration/**/*~
.untaped/orchestration/**/*.swp
.untaped/orchestration/**/*.swo
.untaped/orchestration/**/*.tmp
.untaped/orchestration/**/.#*
.untaped/orchestration/**/#*
